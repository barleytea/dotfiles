{
  "env": {
    "EDITOR": "nvim",
    "GH_CONFIG_DIR": "~/.config/github-cli"
  },
  "sandbox": {
    "enabled": true,
    "enableWeakerNetworkIsolation": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": ["docker", "gh", "security"],
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "read": {
        "denyOnly": [
          "/var/run/docker.sock",
          ".env*",
          "*.env",
          "*credential*",
          "*.pem",
          "*.key",
          "*.secret"
        ],
        "allowLocalBinding": true
      },
      "write": {
        "allowOnly": [
          ".",
          "/tmp/claude",
          "/private/tmp/claude",
          "/dev/stdout",
          "/dev/stderr",
          "/dev/null"
        ],
        "denyWithinAllow": [
          ".claude/settings.json",
          ".claude/settings.local.json"
        ]
      }
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "cache.nixos.org",
        "nixos.org",
        "search.nixos.org",
        "registry.npmjs.org",
        "nodejs.org",
        "*.googleapis.com",
        "*.pkg.dev",
        "*.amazonaws.com",
        "*.aws.amazon.com"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git stash:*)",
      "Bash(git checkout -b:*)",
      "Bash(git pull:*)",
      "Bash(find:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(touch:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(awk:*)",
      "Bash(make:*)",
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(nix build:*)",
      "Bash(nix flake check:*)",
      "Bash(nixos-rebuild build:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npx eslint:*)",
      "Bash(npx tsc:*)",
      "Bash(npx tsx:*)",
      "Bash(npx vitest:*)",
      "Bash(npx cdk synth:*)"
    ],
    "deny": [
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ]
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 1
  },
  "enabledPlugins": {},
  "language": "Japanese",
  "effortLevel": "medium",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-skill.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/difit-cmux-hook",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/save-session.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
